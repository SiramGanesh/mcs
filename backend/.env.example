# ============================================
# Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Command: cp .env.example .env
# ============================================

# Port number for the Express server
PORT=5000

# MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/complaint-system
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/complaint-system
MONGODB_URI=mongodb://localhost:27017/complaint-system

# JWT Secret Key - CHANGE THIS to a random string in production!
# You can generate one at: https://randomkeygen.com/
JWT_SECRET=your_super_secret_key_change_this_in_production

# JWT Token Expiry (how long the login token lasts)
JWT_EXPIRE=7d
